# ================================================================
#  MFA Ambassadors 2026 - Environment Variables
#
#  HOW TO GET THESE VALUES:
#  1. Go to https://supabase.com and open your project
#  2. Click Settings (gear icon) -> API
#  3. Copy the values into a NEW file called .env
#
#  NEVER commit .env to git - it contains secret keys!
#  .gitignore already excludes it.
# ================================================================

# Your Supabase project URL
# Found at: Supabase Dashboard -> Settings -> API -> Project URL
# Example:  https://abcdefghijklmno.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase SERVICE ROLE key (NOT the anon/public key!)
# Found at: Supabase Dashboard -> Settings -> API -> service_role -> Reveal
# This key bypasses Row Level Security - keep it secret, server-side only!
# It starts with: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_KEY_HERE

# Port for local development only (Vercel ignores this)
PORT=3000

# Allowed frontend origin for CORS
# Local dev:   CORS_ORIGIN=*
# Production:  CORS_ORIGIN=https://your-app.vercel.app
CORS_ORIGIN=*

# Set to 'production' on Vercel, 'development' locally
NODE_ENV=development
