{
  "version": 2,
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control",           "value": "no-store, no-cache, must-revalidate" },
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control",   "value": "no-cache" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}